# Kalshi WNBA forecast bot — environment
#
# The ONLY required credentials are the Kalshi REST keys (for reading
# orderbooks / placing paper orders). The data layer (ESPN) needs no key.
KALSHI_API_KEY_ID=replace-with-your-kalshi-key-id
KALSHI_PRIVATE_KEY_PATH=/absolute/path/to/kalshi_api_key.pem

# Optional — enables the Vegas-moneyline inference signal. Leave unset
# to run without it (the model trains and trades fine without).
# THE_ODDS_API_KEY=
